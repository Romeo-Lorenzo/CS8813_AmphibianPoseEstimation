# Projects-level ignore rules
# Goal: keep lightweight, reproducible artifacts (metrics/configs/scripts)
# and avoid pushing large raw media/training data.

# Media (videos + images)
**/*.mp4
**/*.avi
**/*.mov
**/*.mkv
**/*.webm
**/*.wmv
**/*.mpg
**/*.mpeg
**/*.png
**/*.jpg
**/*.jpeg
**/*.bmp
**/*.gif
**/*.tif
**/*.tiff

# SLEAP/DLC raw label packages and heavy intermediates
**/*.slp
**/*.pkg.slp
**/*.h5
**/*.pickle

# Large training/inference artifact folders
**/videos/**
**/labeled-data/**
**/training-datasets/**
**/holdout_backup/**
**/dlc-models/**
**/models/**
**/predictions/**

# Keep evaluation outputs and important metadata by default
# (csv/json/yaml/txt/py/npz/ckpt are not ignored)
